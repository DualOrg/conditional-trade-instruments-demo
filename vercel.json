{
  "cleanUrls": true,
  "functions": {
    "server.mjs": {
      "includeFiles": "{index.html,app.js,styles.css,concept.png,dual-conditional-trade-template.json,api/**}"
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
